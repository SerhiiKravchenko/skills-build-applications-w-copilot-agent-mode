{
    "version": "2.0.0",
    "configurations": [
        {
            "name": "Run Django Server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "justMyCode": true,
            "env": {
                "CODESPACE_NAME": "${env:CODESPACE_NAME}"
            }
        }
    ]
}
